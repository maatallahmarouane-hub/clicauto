rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Catalogue produits : lecture publique, écriture admin authentifié
    match /products/{docId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Véhicules : lecture publique, écriture admin authentifié
    match /vehicles/{docId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Commandes : écriture publique (clients), lecture admin uniquement
    match /orders/{docId} {
      allow read:  if request.auth != null;
      allow write: if true;
    }

    // Messages clients : écriture publique (clients), lecture admin uniquement
    match /messages/{docId} {
      allow read:  if request.auth != null;
      allow write: if true;
    }

    // Fournisseurs : admin uniquement
    match /fournisseurs/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
